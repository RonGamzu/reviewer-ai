# ─── Frontend (exposed to browser) ───────────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_APP_VERSION=1.0.0

# ─── Secrets (fill these in before running) ──────────────────────────────────
JWT_SECRET=
AI_SERVICE_SECRET=
GEMINI_API_KEY=
